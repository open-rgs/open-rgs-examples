{
  "name": "open-rgs-examples",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "description": "A gallery of worked open-rgs games — Limbo, Dice, Plinko, Mines, Tower, Chicken Road, Crash, Blackjack — each one bootable with `bun run dev` and math-testable with the simulator.",
  "homepage": "https://examples.open-rgs.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-rgs/open-rgs-examples.git"
  },
  "type": "module",
  "engines": {
    "bun": ">=1.1.0"
  },
  "workspaces": [
    "packages/*",
    "games/*",
    "tools/*"
  ],
  "scripts": {
    "sim": "bun tools/simulator/src/index.ts",
    "play": "bun tools/play/src/index.ts",
    "typecheck": "bun --filter '*' run typecheck",
    "docs:build": "bun docs/build.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
